{
  "name": "retrofit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Retrofit — an autonomous web remediation engine. One engine, swappable policies.",
  "scripts": {
    "serve": "http-server target -p 8080 -c-1 --silent",
    "crawl": "node harness/crawl.mjs",
    "verify": "node harness/verify-policy.mjs",
    "capture": "node harness/visual-capture.mjs",
    "locales": "node harness/locale-shots.mjs",
    "report": "node harness/report.mjs",
    "keyboard": "node harness/keyboard.mjs",
    "rubric": "node harness/rubric-status.mjs",
    "retrofit": "node harness/retrofit.mjs",
    "dashboard": "node harness/dashboard.mjs",
    "smoke": "node harness/smoke.mjs",
    "test": "node harness/retrofit.mjs --policy a11y && node harness/retrofit.mjs --policy i18n"
  },
  "dependencies": {
    "axe-core": "^4.12.1",
    "playwright": "^1.56.1"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
